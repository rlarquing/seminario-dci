// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Tabla de Alumnos - Información personal completa (según Excel)
model Alumno {
  id                                  Int      @id @default(autoincrement())
  numeroExpediente                    Int      @unique  // No Expediente
  nombre                              String
  apellidos                           String
  ci                                  String   @unique  // Carnet de Identidad
  telefono                            String?
  email                               String?
  pasaporte                           String?  // No Pasaporte
  direccion                           String?  // Dirección particular
  genero                              String?  // Sexo: M/F
  nombreIglesia                       String?  // Nombre de la Iglesia y Dirección
  nombrePastor                        String?  // Nombre del Pastor
  tomaHuellaBiometrica                Boolean  @default(false)  // Toma de huella biométricas
  entregaFoto                         Boolean  @default(false)  // Entrega de foto
  pagoCuotas                          String?  // Pago de Cuotas por meses
  disposicionCampoMisionero           Boolean  @default(false)  // Desea participar del campo misionero
  habilidades                         String?  // Habilidades
  createdAt                           DateTime @default(now())
  updatedAt                           DateTime @updatedAt

  // Relaciones
  notas                               Nota[]

  @@map("alumnos")
}

// Tabla de Profesores (según Excel)
model Profesor {
  id                       Int      @id @default(autoincrement())
  nombre                   String
  apellidos                String
  ci                       String   // Carnet de Identidad
  telefono                 String?
  email                    String?
  genero                   String?  // Sexo: M/F
  nombreIglesia            String?  // Nombre de la Iglesia y Dirección
  nombrePastor             String?  // Nombre del Pastor
  tomaHuellaBiometrica     Boolean  @default(false)  // Toma de huella biométricas
  entregaFoto              Boolean  @default(false)  // Entrega de foto
  asignaturaId             Int?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  // Relaciones
  asignatura               Asignatura? @relation(fields: [asignaturaId], references: [id])

  @@map("profesores")
}

// Tabla de Asignaturas
model Asignatura {
  id                Int      @id @default(autoincrement())
  nombre            String
  codigo            String?  @unique
  profesores        Profesor[]
  notas             Nota[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("asignaturas")
}

// Tabla de Notas (según Excel)
model Nota {
  id                Int      @id @default(autoincrement())
  alumnoId          Int
  asignaturaId      Int
  nota              Float?   // Nota numérica
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relaciones
  alumno            Alumno    @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  asignatura        Asignatura @relation(fields: [asignaturaId], references: [id])

  @@unique([alumnoId, asignaturaId]) // Un alumno solo puede tener una nota por asignatura
  @@map("notas")
}

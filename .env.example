# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# El sistema detecta automáticamente qué usar
# ============================================

# ------------------------------------------------
# OPCIÓN 1: DESARROLLO LOCAL (SQLite)
# ------------------------------------------------
# Para trabajar localmente, solo necesitas DATABASE_URL apuntando a un archivo
# La base de datos se crea automáticamente con: npm run db:push

DATABASE_URL="file:./prisma/db/custom.db"


# ------------------------------------------------
# OPCIÓN 2: PRODUCCIÓN CON TURSO (Vercel)
# ------------------------------------------------
# Turso usa TURSO_DATABASE_URL (lo crea automáticamente Vercel)
# Solo necesitas agregar TURSO_AUTH_TOKEN

# TURSO_DATABASE_URL="libsql://tu-base.turso.io"
# TURSO_AUTH_TOKEN="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."


# ============================================
# INSTRUCCIONES
# ============================================
#
# 🖥️ DESARROLLO LOCAL:
# --------------------
# 1. Mantén DATABASE_URL="file:./prisma/db/custom.db"
# 2. npm run db:push  (crea las tablas)
# 3. npm run dev
#
#
# ☁️ PRODUCCIÓN EN VERCEL + TURSO:
# --------------------------------
# 1. Crea una base de datos en https://turso.tech
# 2. Conecta Turso a Vercel (se configura TURSO_DATABASE_URL automáticamente)
# 3. Agrega TURSO_AUTH_TOKEN en Vercel:
#    - Ve a Turso → Settings → Database Authentication → Create Token
#    - Copia el token y agrégalo en Vercel → Settings → Environment Variables
# 4. Redespliega en Vercel
# 5. Inicializa la BD: curl -X POST https://tu-app.vercel.app/api/init-db
#
# ============================================

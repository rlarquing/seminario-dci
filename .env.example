# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================

# OPCIÓN 1: DESARROLLO LOCAL (SQLite)
# Usar esta configuración para trabajar localmente
# La base de datos se crea automáticamente en prisma/db/custom.db

DATABASE_URL="file:./db/custom.db"


# OPCIÓN 2: PRODUCCIÓN CON TURSO
# Descomenta estas líneas y comenta la de arriba para usar Turso
# Obtén estos valores en https://turso.tech

# DATABASE_URL="libsql://tu-base-de-datos.turso.io"
# TURSO_AUTH_TOKEN="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."


# ============================================
# INSTRUCCIONES:
# ============================================
# 
# PARA DESARROLLO LOCAL:
# 1. Usa DATABASE_URL="file:./db/custom.db"
# 2. Ejecuta: npm run db:push
# 3. Ejecuta: npm run dev
#
# PARA PRODUCCIÓN (TURSO):
# 1. Crea una base de datos en https://turso.tech
# 2. Copia la URL (ej: libsql://mi-base-abc.turso.io)
# 3. Crea un token de autenticación en Settings > Database Authentication
# 4. Configura las variables DATABASE_URL y TURSO_AUTH_TOKEN
# 5. Despliega en Vercel
# 6. Visita: https://tu-app.vercel.app/api/init-db (método POST)
#    O ejecuta: curl -X POST https://tu-app.vercel.app/api/init-db
#
# ============================================
